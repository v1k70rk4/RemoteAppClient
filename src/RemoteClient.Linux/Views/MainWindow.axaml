<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RemoteClient.Linux.Views.MainWindow"
        Width="1080" Height="640" MinWidth="640" MinHeight="440"
        Title="RemoteAppClient — Operator (Linux)">

  <Grid>
    <!-- Sign-in -->
    <Border x:Name="LoginPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Width="360">
      <StackPanel Spacing="8">
        <TextBlock Text="RemoteAppClient" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
        <TextBlock x:Name="SubtitleText" Text="Operator console (Linux)" Opacity="0.7" HorizontalAlignment="Center" Margin="0,0,0,10"/>
        <Button x:Name="UpdateLink" IsVisible="False" Click="OnOpenReleases"
                Background="Transparent" BorderThickness="0" Padding="2" Cursor="Hand"
                Foreground="#2E86DE" HorizontalAlignment="Center" Margin="0,0,0,8"/>
        <TextBox x:Name="ServerBox" PlaceholderText="https://server"/>
        <TextBox x:Name="UserBox" PlaceholderText="username" TextChanged="OnUserChanged"/>
        <TextBox x:Name="PassBox" PlaceholderText="password" PasswordChar="•"/>
        <TextBox x:Name="TotpBox" PlaceholderText="TOTP (if configured)"/>
        <CheckBox x:Name="RememberCheck" Content="Remember this device (skip TOTP for 90 days)" IsChecked="True"/>
        <Button x:Name="LoginBtn" Content="Sign in" HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center" Click="OnLogin"/>
        <Button x:Name="ForgotBtn" Content="Forgot password?" Background="Transparent"
                BorderThickness="0" HorizontalAlignment="Center" Click="OnForgot"/>
        <TextBlock x:Name="LoginStatus" Foreground="#C0392B" TextWrapping="Wrap"/>
      </StackPanel>
    </Border>

    <!-- Devices -->
    <DockPanel x:Name="DevicesPanel" IsVisible="False" Margin="12">
      <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
        <TextBox x:Name="SearchBox" Width="260" PlaceholderText="search hostname…" TextChanged="OnSearch"/>
        <Button x:Name="ConnectBtn" Content="Connect (VNC)" Click="OnConnect"/>
        <Button x:Name="RefreshBtn" Content="Refresh" Click="OnRefresh"/>
        <Button x:Name="SettingsBtn" Content="Settings" Click="OnSettings"/>
        <TextBlock x:Name="DevStatus" VerticalAlignment="Center" Opacity="0.8"/>
      </StackPanel>
      <Grid ColumnDefinitions="*,340">
        <DataGrid x:Name="DeviceList" Grid.Column="0"
                  SelectionMode="Single" SelectionChanged="OnDeviceSelected"
                  CanUserSortColumns="True" CanUserResizeColumns="True"
                  IsReadOnly="True" GridLinesVisibility="Horizontal" HeadersVisibility="Column">
          <DataGrid.Columns>
            <DataGridTextColumn Binding="{Binding Hostname}" Width="*" MinWidth="120"/>
            <DataGridTextColumn Binding="{Binding Group}" Width="Auto" MinWidth="100"/>
            <DataGridTextColumn Binding="{Binding NoteText}" Width="2*" MinWidth="100"/>
            <DataGridTextColumn Binding="{Binding OnlineText}" Width="Auto" MinWidth="64"/>
            <DataGridTextColumn Binding="{Binding LastSeen, StringFormat='{}{0:g}'}" Width="Auto" MinWidth="120"/>
          </DataGrid.Columns>
        </DataGrid>
        <Border Grid.Column="1" Margin="8,0,0,0" BorderBrush="#40808080" BorderThickness="1" CornerRadius="6">
          <ScrollViewer>
            <StackPanel x:Name="DetailPanel" Margin="12,10"/>
          </ScrollViewer>
        </Border>
      </Grid>
    </DockPanel>

    <!-- VNC settings (color + scaling) -->
    <Border x:Name="SettingsPanel" IsVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" Width="380">
      <StackPanel Spacing="10">
        <TextBlock Text="VNC settings" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
        <TextBlock Text="Scaling" Opacity="0.7"/>
        <ComboBox x:Name="ScaleBox" HorizontalAlignment="Stretch">
          <ComboBoxItem Tag="auto" Content="Auto — fit to window (recommended)"/>
          <ComboBoxItem Tag="1.0" Content="100% (1:1)"/>
          <ComboBoxItem Tag="0.75" Content="75%"/>
          <ComboBoxItem Tag="0.5" Content="50%"/>
          <ComboBoxItem Tag="none" Content="Off — no scaling"/>
        </ComboBox>
        <CheckBox x:Name="ColorCheck" Content="256-color (low bandwidth, -bgr233)"/>
        <TextBlock x:Name="LangLabel" Text="Language" Opacity="0.7" Margin="0,6,0,0"/>
        <ComboBox x:Name="LangBox" HorizontalAlignment="Stretch">
          <ComboBoxItem Tag="auto" Content="Auto (system)"/>
          <ComboBoxItem Tag="en" Content="English"/>
          <ComboBoxItem Tag="hu" Content="Magyar"/>
        </ComboBox>
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
          <Button x:Name="SetSaveBtn" Content="Save" Click="OnSettingsSave"/>
          <Button x:Name="SetBackBtn" Content="← Back" Click="OnSettingsBack"/>
        </StackPanel>
        <TextBlock x:Name="SetStatus" Opacity="0.8"/>
      </StackPanel>
    </Border>

    <!-- Password recovery (reuses the Windows ForgotPasswordForm labels) -->
    <Border x:Name="RecoveryPanel" IsVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" Width="400">
      <ScrollViewer MaxHeight="580">
        <StackPanel Spacing="8">
          <TextBlock x:Name="RecTitle" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
          <TextBlock x:Name="RecStep1" TextWrapping="Wrap" Opacity="0.8"/>
          <TextBox x:Name="RecServerBox" PlaceholderText="https://server"/>
          <TextBox x:Name="RecUserBox"/>
          <TextBox x:Name="RecEmailBox"/>
          <Button x:Name="RecRequestBtn" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="OnRecoveryRequest"/>
          <TextBlock x:Name="RecStep2" TextWrapping="Wrap" Opacity="0.8" Margin="0,8,0,0"/>
          <TextBox x:Name="RecTokenBox" PlaceholderText="Kapott token"/>
          <TextBox x:Name="RecPassBox" PasswordChar="•"/>
          <Button x:Name="RecSetBtn" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="OnRecoverySet"/>
          <TextBlock x:Name="RecStatus" Foreground="#C0392B" TextWrapping="Wrap"/>
          <Button x:Name="RecBackBtn" Content="← Back to sign-in" Background="Transparent"
                  BorderThickness="0" HorizontalAlignment="Center" Click="OnRecoveryBack"/>
        </StackPanel>
      </ScrollViewer>
    </Border>
  </Grid>
</Window>
