# deploy/config.env.example
# Copy to config.env for an UNATTENDED run (every value here skips its prompt).
#   cp config.env.example config.env && nano config.env && ./setup.sh

# --- required ---
RAC_DOMAIN="racd.example.com"
RAC_ACME_EMAIL="admin@example.com"

# --- optional (sensible defaults shown) ---
# RAC_BASTION_HOST="racd.example.com"        # where agents SSH (defaults to RAC_DOMAIN)

# Database: leave RAC_DB_CONN empty to be asked (own DB vs install MariaDB locally).
# To use an existing DB unattended, set the full connection string:
# RAC_DB_CONN="Server=db.host;Port=3306;Database=remoteserver;User Id=remoteserver;Password=secret"
# RAC_DB_NAME="remoteserver"

# Server package: a local tarball path; if unset/missing, the latest GitHub release is downloaded.
# RAC_PKG="/tmp/remoteserver.tar.gz"

# Run without any prompts (uses defaults / values above for everything).
# RAC_NONINTERACTIVE=1
